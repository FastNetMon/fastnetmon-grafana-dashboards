              "limit": 0,
              "mode": "trend",
              "orderBy": [],
              "queryType": "timeseries",
              "table": "$protocol_version"
            }
          },
          "pluginVersion": "4.14.0",
          "queryType": "timeseries",
          "rawSql": "SELECT $__timeInterval(metricDateTime) as time, concat(dictGetOrDefault('fastnetmon.asn_information', 'asn_name', asn_number, 'Unknown'), ' AS',toString(asn_number)), avg(multiIf('${protocol}' = 'total', bits_incoming, '${protocol}' = 'udp', udp_bits_incoming, '${protocol}' = 'tcp', tcp_bits_incoming, '${protocol}' = 'icmp', icmp_bits_incoming, '${protocol}' = 'fragmented', fragmented_bits_incoming, '${protocol}' = 'tcp_syn', tcp_syn_bits_incoming, 0)) as \" \" FROM \"fastnetmon\".\"$protocol_version\" WHERE asn_number in ( select asn_number from (\n\n  SELECT asn_number, sum(multiIf('${protocol}' = 'total', bits_incoming, '${protocol}' = 'udp', udp_bits_incoming, '${protocol}' = 'tcp', tcp_bits_incoming, '${protocol}' = 'icmp', icmp_bits_incoming, '${protocol}' = 'fragmented', fragmented_bits_incoming, '${protocol}' = 'tcp_syn', tcp_syn_bits_incoming, 0)) as length\n  FROM \"fastnetmon\".\"$protocol_version\"\n  WHERE $__timeFilter(metricDateTime) AND ( metricDateTime  >= $__fromTime AND metricDateTime <= $__toTime )\n  GROUP BY asn_number\n  ORDER BY length DESC\n  LIMIT 10\n)) and $__timeFilter(metricDateTime) AND   ( metricDateTime  >= $__fromTime AND metricDateTime <= $__toTime )\n GROUP BY asn_number, time ORDER BY time ASC ",
          "refId": "A"
        }
      ],
      "title": "Incoming traffic",
      "type": "timeseries"
