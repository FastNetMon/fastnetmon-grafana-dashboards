              "database": "fastnetmon",
              "filters": [
                {
                  "condition": "AND",
                  "filterType": "custom",
                  "hint": "time",
                  "key": "metricDateTime",
                  "operator": "WITH IN DASHBOARD TIME RANGE",
                  "restrictToFields": [
                    {
                      "label": "metricDateTime",
                      "name": "metricDateTime",
                      "picklistValues": [],
                      "type": "DateTime"
                    }
                  ],
                  "type": "datetime"
